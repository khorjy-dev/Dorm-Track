VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# On Vercel: full URL with https://. Used as OAuth return URL for all non-localhost visits.
# VITE_APP_ORIGIN=https://incidenttrack.olivetacademy.org
#
# Supabase → Authentication → URL Configuration: add Site URL + Redirect URLs for that domain and localhost.

# Resend (configure in Supabase Dashboard → Project Settings → Edge Functions → Secrets, or `supabase secrets set`)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Incident Track <notifications@your-verified-domain.com>
# WEBHOOK_SECRET=optional-random-string-matching-database-webhook-header
